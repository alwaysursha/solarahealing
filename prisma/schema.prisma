generator client {
  provider      = "prisma-client-js"
  engineType    = "client"
  compilerBuild = "small"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
  COMPLETED
}

enum OrderItemType {
  COURSE
  WORKSHOP
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(USER)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  orders   Order[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SiteSettings {
  id              Int      @id @default(1)
  name            String
  tagline         String
  sanskrit        String
  sanskritMeaning String
  description     String
  seoTitle        String
  metaDescription String
  phone           String
  email           String
  whatsapp        String
  address         String
  cta             String
  updatedAt       DateTime @updatedAt
}

model OnlineCourse {
  id          String   @id
  title       String
  description String
  dateLabel   String
  duration    String
  badge       String
  priceCad    Int
  image       String
  imageAlt    String
  level       String
  published   Boolean  @default(true)
  sortOrder   Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model Workshop {
  id          String   @id
  title       String
  description String
  dateLabel   String
  duration    String
  badge       String
  priceCad    Int
  seatsTotal  Int      @default(20)
  seatsBooked Int      @default(0)
  image       String
  imageAlt    String
  published   Boolean  @default(true)
  sortOrder   Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model Article {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  excerpt   String
  body      String   @db.Text
  category  String
  image     String
  imageAlt  String
  featured  Boolean  @default(false)
  published Boolean  @default(true)
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
}

model PageSection {
  id         String   @id
  pageKey    String
  sectionKey String
  label      String
  content    String   @db.Text
  updatedAt  DateTime @updatedAt

  @@unique([pageKey, sectionKey])
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  status        OrderStatus @default(PENDING)
  totalCad      Int
  customerName  String
  customerEmail String
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]
}

model OrderItem {
  id           String        @id @default(cuid())
  orderId      String
  itemType     OrderItemType
  itemId       String
  title        String
  quantity     Int           @default(1)
  unitPriceCad Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
