{
  "name": "solarahealing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:next": "WATCHPACK_POLLING=true next dev --hostname 127.0.0.1 --webpack",
    "build": "next build --webpack",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "eslint",
    "db:init": "bash scripts/ensure-d1.sh",
    "db:migrate:local": "wrangler d1 execute solarahealing --local --file=./scripts/schema.sql",
    "db:migrate:remote": "wrangler d1 execute solarahealing --remote --file=./scripts/schema.sql",
    "db:seed": "tsx scripts/seed-db.ts",
    "db:setup:local": "pnpm db:init && pnpm db:migrate:local && pnpm db:seed",
    "db:setup:remote": "pnpm db:init && pnpm db:migrate:remote && pnpm db:seed"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.42.2",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.30",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "wrangler": "^4.108.0"
  }
}
